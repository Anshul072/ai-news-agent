# Required — AI provider
GEMINI_API_KEY=

# Required — Reddit API app credentials (create at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-news-agent/1.0 (by /u/yourredditusername)

# Optional — comma-separated RSS feed URLs
RSS_FEEDS=https://feeds.feedburner.com/aisummary

# Optional — comma-separated subreddit names (no r/ prefix)
SUBREDDITS=artificial,MachineLearning,LocalLLaMA

# Optional — APScheduler cron expressions
NEWS_SCHEDULE=0 23 * * 1,3,5
SENTIMENT_SCHEDULE=0 8 * * *

# Optional — story clustering cosine-similarity threshold (0–1)
CLUSTERING_THRESHOLD=0.85

# Optional — rolling window for sentiment re-scans (days)
SENTIMENT_WINDOW_DAYS=7
